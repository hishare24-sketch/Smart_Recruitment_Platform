# ===== بيئة الباك-إند (NestJS) =====
NODE_ENV=development
PORT=8000

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ===== القاعدة =====
# الأسهل محليًّا: SQLite داخل العملية (sql.js) — بلا خادم ولا بناء أصلي.
DB_CONNECTION=sqljs
DB_SQLITE_FILE=data/dev.sqlite
# للإنتاج/الفريق: Postgres (بدّل DB_CONNECTION=postgres وفعّل الأسطر التالية)
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=recruitment
# DB_USERNAME=recruitment
# DB_PASSWORD=secret

# نطاق الواجهة المسموح (CORS)
FRONTEND_URL=http://localhost:5173
